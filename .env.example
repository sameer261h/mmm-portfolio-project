# OpenAI powers the campaign-planning agent.
# Leave blank to use the deterministic demo planner.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Ads API credentials.
# Keep these empty until Phase 0 is complete.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Safety switch.
# false = mock mode only. true = allow real Google Ads mutate calls.
GOOGLE_ADS_MUTATE_ENABLED=false

# Guardrail for the UI.
MAX_DAILY_BUDGET_USD=1000
