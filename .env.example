# OpenAI powers the campaign-planning agent.
# Leave blank to use the deterministic demo planner.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Ads API credentials.
# Keep these empty until Phase 0 is complete.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Safety switch.
# false = mock mode only. true = allow real Google Ads mutate calls.
GOOGLE_ADS_MUTATE_ENABLED=false

# Meta (Facebook/Instagram) Marketing API credentials.
# Keep these empty until you've created a Business Manager, developer App,
# Ad Account, and connected Page -- see META_ADS_AGENT_PLAN.md's Phase 0.
META_ADS_APP_ID=
META_ADS_APP_SECRET=
META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=
META_ADS_PAGE_ID=

# Safety switch. Meta has no free "test account" like Google Ads -- keep
# this false until you intend to create real (paused, non-billing) campaigns.
META_ADS_MUTATE_ENABLED=false

# Guardrail for the UI. Shared cap across both Google Ads and Meta Ads.
MAX_DAILY_BUDGET_USD=1000
